rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/assets
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - User ID of the owner
    //   - type: string (required) - Asset type
    //   - name: string (required) - Asset name
    //   - shares: number (required) - Number of shares
    //   - costBasis: number (required) - Cost basis
    //   - currentPrice: number (required) - Current price
    //   - note: string (optional) - Note
    //
    // Collection: users/{userId}/history
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - User ID of the owner
    //   - date: string (required) - Date string
    //   - totalAssets: number (required) - Total assets
    //   - totalLiabilities: number (required) - Total liabilities
    //   - netWorth: number (required) - Net worth
    //   - note: string (optional) - Note
    //
    // Collection: users/{userId}/investments
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - User ID of the owner
    //   - date: string (required) - Date string
    //   - amount: number (required) - Amount invested
    //   - note: string (optional) - Note
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function validOptionalStringLength(field, minLen, maxLen) {
      return !('field' in request.resource.data) || (request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidAsset(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'type', 'name', 'shares', 'costBasis', 'currentPrice', 'note']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.type in ['TW_STOCK', 'US_STOCK', 'CASH_TWD', 'CASH_USD', 'LOAN_TWD'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.shares is number &&
             data.costBasis is number &&
             data.currentPrice is number &&
             (!('note' in data) || (data.note is string && data.note.size() <= 500));
    }

    function isValidHistoryRecord(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'date', 'totalAssets', 'totalLiabilities', 'netWorth', 'note']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 20 &&
             data.totalAssets is number &&
             data.totalLiabilities is number &&
             data.netWorth is number &&
             (!('note' in data) || (data.note is string && data.note.size() <= 500));
    }

    function isValidInvestmentRecord(data) {
      return hasOnlyAllowedFields(['id', 'uid', 'date', 'amount', 'target', 'note']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.date is string && data.date.size() > 0 && data.date.size() < 20 &&
             data.amount is number &&
             (!('target' in data) || (data.target is string && data.target.size() <= 100)) &&
             (!('note' in data) || (data.note is string && data.note.size() <= 500));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read, write: if false; // No direct access to user document right now

      match /assets/{assetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAsset(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidAsset(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }

      match /history/{historyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHistoryRecord(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidHistoryRecord(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }

      match /investments/{investmentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInvestmentRecord(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isDocOwner() && isValidInvestmentRecord(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) && isDocOwner();
      }
    }
  }
}
